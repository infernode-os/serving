# /home/pdfinn/.config/systemd/user/serving-sglang.env
#
# Runtime config for serving-sglang.service. Edit, then
# `systemctl --user daemon-reload && systemctl --user restart serving-sglang`.

# Hephaestus runs SGLang on the dev daemon (SSD-rooted), not the
# production daemon (root-partition, for TAK/NERVA/Ollama). See CLAUDE.md
# in infernode-os/serving for the dual-daemon rules.
DOCKER_HOST=unix:///run/docker-dev.sock

# Pin to a specific image SHA in production. :orin-latest is fine for dev.
IMAGE=ghcr.io/infernode-os/serving-sglang:orin-24b8d03

# Smoke target — fast load, validates the unit shape itself.
# For production, swap to an 8B-class Llama-3.1 (and uncomment EXTRA_ARGS):
#   MODEL_PATH=unsloth/Meta-Llama-3.1-8B-Instruct
#   EXTRA_ARGS=--tokenizer-path /opt/tokenizers/llama-3.1
MODEL_PATH=TinyLlama/TinyLlama-1.1B-Chat-v1.0
EXTRA_ARGS=

PORT=30000

# 0.25 leaves headroom while Ollama coexists during the switcher transition.
# Once `llmctl` enforces "one backend at a time", raise to 0.5–0.6.
MEM_FRACTION_STATIC=0.25

HF_CACHE=/mnt/orin-ssd/huggingface
